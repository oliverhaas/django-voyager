{#def request, notifications=None #}

{% set notifs = notifications or [] %}
{% set unread_count = notifs|selectattr("read", "false")|list|length if notifs else 0 %}

<div class="dropdown dropdown-end" x-data="{ open: false }">
  <div tabindex="0"
       role="button"
       class="btn btn-ghost btn-circle"
       @click="open = !open">
    <div class="indicator">
      <i class="icon icon-lucide-bell h-5 w-5"></i>
      {% if unread_count > 0 %}
        <span class="badge badge-xs badge-primary indicator-item">{{ unread_count }}</span>
      {% endif %}
    </div>
  </div>
  <div x-show="open"
       x-transition
       @click.outside="open = false"
       tabindex="0"
       class="dropdown-content bg-base-100 rounded-box z-10 mt-3 w-80 shadow-lg">
    <div class="p-3 border-b border-base-200">
      <h3 class="font-semibold text-sm">Notifications</h3>
    </div>
    <ul class="menu menu-sm max-h-64 overflow-y-auto">
      {% for notif in notifs %}
        <li>
          <a class="{{ '' if notif.read else 'font-semibold' }}">
            <div class="flex flex-col gap-0.5">
              <span>{{ notif.message }}</span>
              <span class="text-xs text-base-content/50">{{ notif.time }}</span>
            </div>
          </a>
        </li>
      {% else %}
        <li class="p-4 text-center text-sm text-base-content/50">No notifications</li>
      {% endfor %}
    </ul>
  </div>
</div>
