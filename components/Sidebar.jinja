{#def request #}

<aside class="menu bg-base-100 text-base-content min-h-full w-64 p-4">
  <div class="mb-6">
    <a href="/" class="flex items-center gap-2 text-xl font-bold px-2">
      {{ icon("lucide-atom", class="h-6 w-6 text-primary") }}
      Voyager
    </a>
  </div>
  <ul>
    <li>
      <a href="/"
         class="{{ 'active' if request.path == '/' else '' }}">
        {{ icon("lucide-layout-dashboard", class="h-4 w-4") }}
        Dashboard
      </a>
    </li>
    <li>
      <a href="/experiments/"
         class="{{ 'active' if '/experiments' in request.path else '' }}">
        {{ icon("lucide-flask-conical", class="h-4 w-4") }}
        Experiments
      </a>
    </li>
    <li>
      <a href="/elements/"
         class="{{ 'active' if '/elements' in request.path else '' }}">
        {{ icon("lucide-circle-dot", class="h-4 w-4") }}
        Elements
      </a>
    </li>
    <li>
      <a href="/accelerators/"
         class="{{ 'active' if '/accelerators' in request.path else '' }}">
        {{ icon("lucide-zap", class="h-4 w-4") }}
        Accelerators
      </a>
    </li>
  </ul>
  <div class="divider"></div>
  <ul>
    <li>
      <a href="/admin/" hx-boost="false">
        {{ icon("lucide-settings", class="h-4 w-4") }}
        Admin Panel
      </a>
    </li>
    <li>
      <a href="/api/docs" hx-boost="false">
        {{ icon("lucide-file-text", class="h-4 w-4") }}
        API Docs
      </a>
    </li>
  </ul>
</aside>
